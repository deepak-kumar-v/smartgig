datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enums removed for SQLite compatibility, handled as Strings
// V3.3: Re-introducing Enums for stricter Contract control (Postgres/Prisma is being used)
enum ContractStatus {
  DRAFT
  PENDING_REVIEW
  ACCEPTED
  FINALIZED
  FUNDED
  ACTIVE
  COMPLETED
  CLOSED
  CANCELLED
  REJECTED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  PAID
  DISPUTED
}

enum EscrowStatus {
  PENDING
  FUNDED
  DISPUTED
  CLOSED
}

enum WalletTransactionType {
  DEPOSIT
  ESCROW_LOCK
  ESCROW_RELEASE
  REFUND
  WITHDRAWAL
  PLATFORM_FEE
  ADJUSTMENT
  DISPUTE_RESOLUTION
}

enum RefundReason {
  OPERATIONAL
  DISPUTE_SETTLEMENT
  CONTRACT_CANCELLED
  MANUAL_ADMIN_REFUND
}

enum ChangeRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DisputeStatus {
  OPEN
  DISCUSSION
  PROPOSAL
  ADMIN_REVIEW
  RESOLVED
  CLOSED
}

enum DisputeOutcome {
  FULL_RELEASE
  FULL_REFUND
  PARTIAL_SPLIT
  MUTUAL_CANCELLATION
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("FREELANCER") // Was UserRole
  isSystem      Boolean   @default(false)
  
  // Custom fields
  phone         String?   @unique
  isVerified    Boolean   @default(false)
  trustScore    Float     @default(100.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // App relations
  freelancerProfile FreelancerProfile?
  clientProfile     ClientProfile?
  sentMessages      Message[]
  notifications     Notification[]
  wallet            Wallet?
  auditLogs         AuditLog[]
  deviceFingerprints DeviceFingerprint[]
  strikes           Strike[]
  
  // Conversations participation (simplification for m-n)
  conversations     ConversationParticipant[]
  
  // New Backend Relations
  paymentMethods    PaymentMethod[]
  withdrawalRequests WithdrawalRequest[]
  callParticipation CallParticipant[]

  // Admin arbitration relations
  adminMsgsSent       DisputeAdminMessage[]   @relation("AdminMsgSender")
  adminMsgsReceived   DisputeAdminMessage[]   @relation("AdminMsgRecipient")
  adminEvidenceUploads DisputeAdminEvidence[]  @relation("AdminEvidenceUploader")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? // Removed @db.Text
  access_token       String? // Removed @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? // Removed @db.Text
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FreelancerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  
  title         String
  bio           String?
  hourlyRate    Float
  availability  String?  @default("FULL_TIME") // Was Availability enum
  skills        Skill[]
  
  portfolio     PortfolioItem[]
  proposals     Proposal[]
  reviews       Review[]
  services      ServiceListing[]
  contracts     Contract[]
  invoices      Invoice[]
  changeRequests MilestoneChangeRequest[]
}

model ClientProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  
  companyName   String?
  industry      String?
  
  jobPosts      JobPost[]
  proposals     Proposal[] // Received proposals
  contracts     Contract[]
  invoices      Invoice[]
}

model Skill {
  id                 String             @id @default(cuid())
  name               String
  freelancerProfiles FreelancerProfile[]
  jobPosts           JobPost[]
}

model PortfolioItem {
  id           String             @id @default(cuid())
  freelancerId String
  freelancer   FreelancerProfile  @relation(fields: [freelancerId], references: [id])
  title        String
  description  String
  thumbnailUrl String
  projectUrl   String?
  createdAt    DateTime           @default(now())
}

model JobPost {
  id          String        @id @default(cuid())
  clientId    String
  client      ClientProfile @relation(fields: [clientId], references: [id])
  
  // Core Content (V3.2)
  title         String
  overview      String       // Short summary (required)
  descriptionMd String       // Markdown content (required)
  
  // Classification
  category      String
  subcategory   String?
  
  // Budget
  budgetType    String       @default("FIXED") // FIXED, HOURLY
  budgetMin     Float?       // For hourly ranges
  budgetMax     Float        // Primary budget value
  
  // Timeline
  projectType   String       @default("ONE_TIME") // ONE_TIME, ONGOING
  duration      String?
  weeklyHours   Int?
  
  // Location
  isRemote      Boolean      @default(true)
  regions       String?      // Comma-separated regions
  
  // Settings
  visibility      String     @default("PUBLIC") // PUBLIC, INVITE_ONLY
  allowTrialTask  Boolean    @default(false)
  contractToHire  Boolean    @default(false)
  experienceLevel String?
  
  // Complex Data (JSON)
  screeningQuestions String? // JSON: [{question, type, options?, required}]
  attachments        String? // JSON: [{name, size, type, url?}]
  
  // Status
  status      String        @default("OPEN")
  
  // Relations
  skills      Skill[]
  proposals   Proposal[]
  createdAt   DateTime      @default(now())
}

model Proposal {
  id                 String             @id @default(cuid())
  jobId              String
  job                JobPost            @relation(fields: [jobId], references: [id])
  freelancerId       String
  freelancer         FreelancerProfile  @relation(fields: [freelancerId], references: [id])
  clientId           String
  client             ClientProfile      @relation(fields: [clientId], references: [id])
  
  // Core Proposal Data
  coverLetter        String
  proposedRate       Float
  rateType           String             @default("FIXED") // FIXED, HOURLY
  availability       String?
  availabilityHoursPerWeek Int?
  expectedStartDate  DateTime?
  estimatedDuration  String?
  
  // Trial / Contract
  acceptsTrialTask   Boolean            @default(false)
  trialTaskProposal  String?
  contractToHireAcceptance Boolean?
  
  // Complex Data (JSON stored as String for cross-DB compatibility)
  milestones         String?            // JSON: {title, description, amount, duration}[]
  totalMilestoneAmount Float?
  screeningAnswers   String?            // JSON: Record<questionId, answer>
  selectedPortfolioIds String?          // JSON: string[]
  attachments        String?            // JSON: [{name, size, type, url?}]
  hourlyWorkPlan     String?            // JSON: [{title, description, hourRange}] - Optional, non-binding
  
  // Meta / System Fields
  status             String             @default("SUBMITTED") // DRAFT, SUBMITTED, WITHDRAWN, ACCEPTED, REJECTED
  isDraft            Boolean            @default(false)
  confidenceScore    Float?
  boosted            Boolean?
  privateNotes       String?
  lastEditedAt       DateTime?
  
  // Timestamps
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  
  // Relations
  conversation       Conversation?
  contracts          Contract[]

  // Unique constraint: one proposal per freelancer per job
  @@unique([jobId, freelancerId])
}

model Review {
  id               String            @id @default(cuid())
  freelancerId     String
  freelancer       FreelancerProfile @relation(fields: [freelancerId], references: [id])
  rating           Int
  comment          String
  createdAt        DateTime          @default(now())
}

model ServiceListing {
  id               String            @id @default(cuid())
  freelancerId     String
  freelancer       FreelancerProfile @relation(fields: [freelancerId], references: [id])
  
  title            String
  description      String
  category         String
  tags             String
  basePrice        Float
  deliveryDays     Int
  revisions        Int
  status           String            @default("DRAFT") // Was ServiceStatus
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Contract {
  id            String            @id @default(cuid())
  proposalId    String
  proposal      Proposal          @relation(fields: [proposalId], references: [id])
  clientId      String
  client        ClientProfile     @relation(fields: [clientId], references: [id])
  freelancerId  String
  freelancer    FreelancerProfile @relation(fields: [freelancerId], references: [id])
  
  title         String
  totalBudget   Float
  status        ContractStatus @default(DRAFT)
  commissionRate Decimal       @db.Decimal(5, 4) // Snapshotted immutably at FINALIZED — non-nullable after backfill
  finalizedAt   DateTime?
  acceptedAt    DateTime?
  terms         String
  type          String   @default("FULL") // TRIAL, FULL
  startDate     DateTime?
  endDate       DateTime?

  // Standard Contract linked to a Trial
  sourceTrialId String?   @unique
  sourceTrial   Contract? @relation("SourceTrial", fields: [sourceTrialId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  derivedStandard Contract? @relation("SourceTrial")

  milestones    Milestone[]
  escrowAccount EscrowAccount?
  conversation  Conversation?

  // Allow one TRIAL and one FULL contract per proposal
  @@unique([proposalId, type])
}

model Milestone {
  id          String          @id @default(cuid())
  contractId  String
  sequence    Int
  contract    Contract        @relation(fields: [contractId], references: [id])
  title       String
  description String
  amount      Decimal         @db.Decimal(18, 2)
  dueDate     DateTime?
  status      MilestoneStatus @default(PENDING)
  submittedAt DateTime?
  approvedAt  DateTime?

  deliverables       Deliverable[]
  escrowLocks        EscrowLock[]
  changeRequests     MilestoneChangeRequest[]
  dispute            Dispute?

  @@unique([contractId, sequence])
}

model Deliverable {
  id          String   @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])
  fileUrl     String
  comment     String?
  createdAt   DateTime @default(now())
}

model EscrowAccount {
  id         String       @id @default(cuid())
  contractId String       @unique
  contract   Contract     @relation(fields: [contractId], references: [id])
  status     EscrowStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  locks      EscrowLock[]
}

model EscrowLock {
  id          String        @id @default(cuid())
  escrowId    String
  escrow      EscrowAccount @relation(fields: [escrowId], references: [id])
  milestoneId String
  milestone   Milestone     @relation(fields: [milestoneId], references: [id])
  amount      Decimal       @db.Decimal(18, 2)
  released    Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@unique([escrowId, milestoneId])
  @@index([escrowId, released])
  @@index([milestoneId])
}

model Wallet {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id])
  createdAt DateTime       @default(now())
  ledger    WalletLedger[]
}

model WalletLedger {
  id          String                @id @default(cuid())
  walletId    String
  wallet      Wallet                @relation(fields: [walletId], references: [id])
  amount      Decimal               @db.Decimal(18, 2)
  type        WalletTransactionType
  refundReason RefundReason?
  contractId  String?
  milestoneId String?
  createdAt   DateTime              @default(now())

  @@index([walletId, createdAt(sort: Desc)])
  @@index([milestoneId, type])
  @@index([contractId, type])
  @@index([type, createdAt(sort: Desc)])
}

model MilestoneChangeRequest {
  id                  String              @id @default(cuid())
  milestoneId         String
  milestone           Milestone           @relation(fields: [milestoneId], references: [id])
  freelancerId        String
  freelancer          FreelancerProfile   @relation(fields: [freelancerId], references: [id])
  proposedTitle       String?
  proposedDescription String?
  proposedAmount      Float?
  proposedDueDate     DateTime?
  reason              String
  status              ChangeRequestStatus @default(PENDING)
  createdAt           DateTime            @default(now())
  resolvedAt          DateTime?
}

// ============================================================================
// Dispute Resolution System
// ============================================================================

model Dispute {
  id                  String          @id @default(cuid())
  milestoneId         String          @unique
  milestone           Milestone       @relation(fields: [milestoneId], references: [id])
  contractId          String
  openedById          String
  againstUserId       String
  reason              String          // QUALITY_ISSUES | NON_DELIVERY | SCOPE_CREEP | MISSED_DEADLINE | COMMUNICATION | PAYMENT_DISPUTE | OTHER
  description         String
  status              DisputeStatus   @default(OPEN)
  outcome             DisputeOutcome?

  // Resolution
  freelancerPercent   Int?
  resolvedById        String?
  resolutionNote      String?

  // Immutable Snapshot
  snapshot            Json
  snapshotHash        String

  // Deadlines
  discussionDeadline  DateTime?
  proposalDeadline    DateTime?

  // Phase end timestamps (set when phase transitions, enables early-transition detection)
  discussionEndedAt   DateTime?
  proposalEndedAt     DateTime?

  // Mutual phase fast-forward flags (reset on every phase transition)
  phaseAdvanceClient     Boolean @default(false)
  phaseAdvanceFreelancer Boolean @default(false)

  // Timestamps
  createdAt           DateTime        @default(now())
  escalatedAt         DateTime?
  resolvedAt          DateTime?

  // Relations
  messages            DisputeMessage[]
  evidence            DisputeEvidence[]
  proposals           DisputeProposal[]
  adminMessages       DisputeAdminMessage[]
  adminEvidence       DisputeAdminEvidence[]

  @@index([contractId])
  @@index([status])
  @@index([openedById])
}

model DisputeMessage {
  id         String   @id @default(cuid())
  disputeId  String
  dispute    Dispute  @relation(fields: [disputeId], references: [id])
  senderId   String
  content    String
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([disputeId, createdAt])
}

model DisputeEvidence {
  id            String   @id @default(cuid())
  disputeId     String
  dispute       Dispute  @relation(fields: [disputeId], references: [id])
  uploadedById  String
  fileUrl       String
  fileName      String
  fileType      String
  description   String?
  contentHash   String?
  createdAt     DateTime @default(now())

  @@index([disputeId])
}

model DisputeProposal {
  id                String    @id @default(cuid())
  disputeId         String
  dispute           Dispute   @relation(fields: [disputeId], references: [id])
  proposedById      String
  freelancerPercent Int
  reason            String?
  accepted          Boolean?
  createdAt         DateTime  @default(now())
  respondedAt       DateTime?

  @@index([disputeId])
}

model DisputeAdminMessage {
  id          String   @id @default(cuid())
  disputeId   String
  senderId    String
  recipientId String?
  content     String
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender      User     @relation("AdminMsgSender", fields: [senderId], references: [id])
  recipient   User?    @relation("AdminMsgRecipient", fields: [recipientId], references: [id])

  @@index([disputeId])
  @@index([senderId])
}

model DisputeAdminEvidence {
  id           String   @id @default(cuid())
  disputeId    String
  uploadedById String
  fileUrl      String
  fileName     String
  fileType     String
  description  String?
  contentHash  String
  createdAt    DateTime @default(now())

  dispute      Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("AdminEvidenceUploader", fields: [uploadedById], references: [id])

  @@index([disputeId])
}

model Conversation {
  id          String   @id @default(cuid())
  proposalId  String?  @unique
  proposal    Proposal? @relation(fields: [proposalId], references: [id])
  contractId  String?  @unique
  contract    Contract? @relation(fields: [contractId], references: [id])
  createdAt   DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  type           String       @default("TEXT") // TEXT, CALL, AUDIO
  audioUrl       String?      // Only set when type = 'AUDIO'
  callMeta       String?      // JSON: { mode: "audio"|"video", provider: string, meetingUrl: string }
  createdAt      DateTime     @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  
  attachments    Attachment[]
  reactions      MessageReaction[]

  // Reply support (self-relation)
  replyToId   String?
  replyTo     Message?  @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     Message[] @relation("MessageReply")

  // Edit & soft-delete support
  isDeleted   Boolean   @default(false)
  isEdited    Boolean   @default(false)
  editedAt    DateTime?

  // Version history
  versions    MessageVersion[]
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
}

model MessageVersion {
  id                String   @id @default(cuid())
  messageId         String
  message           Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  versionNumber     Int
  content           String
  editedAt          DateTime @default(now())
  editedBy          String
  changeType        String   // ORIGINAL, EDIT, DELETE, RESTORE
  previousVersionId String?
  contentHash       String?  // SHA-256 hash of content for audit integrity

  @@unique([messageId, versionNumber])
  @@index([messageId])
}

model Attachment {
  id          String   @id @default(cuid())
  url         String
  name        String
  size        Int      @default(0) // Added for Phase 2 Chat Attachments
  fileType    String
  
  messageId   String?
  message     Message? @relation(fields: [messageId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Strike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reason    String
  severity  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model DeviceFingerprint {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fingerprint String
  userAgent   String
  ipAddress   String?
  lastSeen    DateTime @default(now())
}

model VideoRoom {
  id          String   @id @default(cuid())
  roomId      String   @unique
  contractId  String?
  hostId      String
  status      String   @default("ACTIVE") // ACTIVE, ENDED
  createdAt   DateTime @default(now())
  endedAt     DateTime?

  participants CallParticipant[]
}

model CallParticipant {
  id        String   @id @default(cuid())
  roomId    String
  room      VideoRoom @relation(fields: [roomId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  joinedAt  DateTime @default(now())
  leftAt    DateTime?
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // CARD, BANK, UPI
  isDefault   Boolean  @default(false)
  details     String   // JSON blob for secure storage
  createdAt   DateTime @default(now())
}

model Invoice {
  id            String            @id @default(cuid())
  invoiceNumber String            @unique
  status        String            // DRAFT, PENDING, PAID, OVERDUE, REFUNDED, CANCELLED
  issueDate     DateTime
  dueDate       DateTime
  paidDate      DateTime?
  
  clientId      String
  client        ClientProfile     @relation(fields: [clientId], references: [id])
  freelancerId  String
  freelancer    FreelancerProfile @relation(fields: [freelancerId], references: [id])
  
  subtotal      Float
  taxRate       Float
  taxAmount     Float
  platformFee   Float
  total         Float
  
  lineItems     InvoiceLineItem[]
  createdAt     DateTime          @default(now())
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  quantity    Int
  unitPrice   Float
  total       Float
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model WithdrawalRequest {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  amount    Decimal          @db.Decimal(18, 2)
  status    WithdrawalStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

// Audit Log Model
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  actorRole   String   // FREELANCER, CLIENT, ADMIN, SYSTEM
  action      String   // Action type (e.g., JOB_CREATED, LOGIN, etc.)
  entityType  String   // Entity affected (USER, JOB, CONTRACT, etc.)
  entityId    String?  // ID of the affected entity
  
  details     Json     // JSON metadata (native JSON type)
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  // Performance indexes
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt(sort: Desc)])
}

// ============================================================================
// Lifecycle Event System (Unified Roadmap)
// ============================================================================

enum ActorRole {
  CLIENT
  FREELANCER
  SYSTEM
}

model LifecycleEvent {
  id            String    @id @default(cuid())
  jobId         String?
  proposalId    String?
  contractId    String?
  milestoneId   String?

  eventType     String    // JOB_POSTED, PROPOSAL_SENT, CONTRACT_DRAFTED, etc.
  devState      String?   // Optional: DRAFT, PENDING_REVIEW, FINALIZED, ACTIVE, etc.
  userMessage   String    // Human-readable description
  actorId       String?
  actorRole     ActorRole // CLIENT, FREELANCER, SYSTEM

  metadata      Json?
  category      String    @default("BUSINESS") // BUSINESS | SYSTEM
  createdAt     DateTime  @default(now())

  @@index([contractId])
  @@index([jobId])
}

// ============================================================================
// Idempotency Key — Prevents duplicate financial action execution
// ============================================================================
model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  action    String
  createdAt DateTime @default(now())
}

// ============================================================================
// System Config — Key-Value Platform Settings
// ============================================================================
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============================================================================
// Financial Mutation Log — Append-Only, Immutable
// ============================================================================
model FinancialMutationLog {
  id          String   @id @default(cuid())
  action      String
  userId      String?
  contractId  String?
  milestoneId String?
  metadata    Json
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([action])
}

// ============================================================================
// Financial Error Log — Append-Only, Immutable
// ============================================================================
model FinancialErrorLog {
  id           String   @id @default(cuid())
  action       String
  userId       String?
  contractId   String?
  milestoneId  String?
  errorMessage String
  stackTrace   String?
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([action])
}
